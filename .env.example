# Veriscope OS - Environment Configuration Example
# Duplicate this file as '.env' in the project root to configure your deployment.

# ==========================================
# LLM Providers (Leave blank to use Sandbox Mode)
# ==========================================
# Gemini API Key (Primary LLM Provider)
GEMINI_API_KEY=

# OpenAI API Key (Alternative LLM Provider)
OPENAI_API_KEY=

# ==========================================
# Web & News Search APIs
# ==========================================
# NewsAPI Key (For historical financial media sentiment scans)
NEWS_API_KEY=

# Tavily Search API Key (For competitor and risk intelligence scans)
TAVILY_API_KEY=

# ==========================================
# Server Configuration
# ==========================================
# Port to run the Express API (default is 5000)
PORT=5000

# CORS Allowed Origins (Comma-separated URLs, or * to allow all)
CORS_ORIGIN=http://localhost:5173

# Database Connection (If persistence integrations are enabled)
DATABASE_URL=

# ==========================================
# Frontend Configuration (Client-side)
# ==========================================
# Client API Target URL (Vite environment variable)
VITE_API_URL=http://localhost:5000
